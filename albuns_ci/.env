#--------------------------------------------------------------------
# BancoCI - Arquivo de configuração de ambiente
# RENOMEIE este arquivo para ".env" antes de usar
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# BANCO DE DADOS
# Altere os valores abaixo conforme seu servidor MySQL
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = albuns_ci
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSÃO
#--------------------------------------------------------------------
# Para usar sessions em banco de dados, configure:
# session.driver    = CodeIgniter\Session\Handlers\DatabaseHandler
# session.savePath  = ci_sessions
# Por padrão usa arquivos (mais simples para desenvolvimento)
